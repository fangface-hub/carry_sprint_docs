@startuml CarrySprintScreenDesign

title CarrySprint Screen Design

skinparam shadowing false
skinparam defaultTextAlignment center

actor "User" as user

rectangle "Browser UI" {
  rectangle "Sign-In Screen" as screen_signin
  rectangle "Top Page" as screen_top
  rectangle "Project Select Screen" as screen_projects
  rectangle "Project Register Screen" as screen_project_register
  rectangle "Sprint Workspace Screen" as screen_workspace
  rectangle "Task Candidate Panel\n(Budget In / Budget Out)" as panel_task
  rectangle "Impact & Estimate Editor" as panel_editor
  rectangle "Resource Settings Screen" as screen_resource
  rectangle "Working-Day Calendar Screen" as screen_calendar
  rectangle "Carry-Over Review Dialog" as dialog_carry
}

user --> screen_signin : Open application
screen_signin --> screen_top : Sign in success
screen_signin --> screen_signin : Sign in failure
screen_top --> screen_projects : Open project select
screen_top --> screen_workspace : Open sprint workspace
screen_top --> screen_resource : Open resource settings
screen_top --> screen_calendar : Open calendar settings
screen_top --> screen_signin : Sign out
screen_projects --> screen_workspace : Open selected project
screen_projects --> screen_project_register : Open project register
screen_project_register --> screen_projects : Register and return
screen_project_register --> screen_projects : Cancel and return

screen_workspace --> panel_task : Show candidate tasks
screen_workspace --> panel_editor : Edit impact / estimate
screen_workspace --> dialog_carry : Review carry-over tasks

screen_workspace --> screen_resource : Open resource settings
screen_workspace --> screen_calendar : Open calendar settings

screen_resource --> screen_workspace : Save and return
screen_calendar --> screen_workspace : Save and return
dialog_carry --> screen_workspace : Confirm and apply

note right of screen_top
  Display menu as buttons.
  Control menu visibility per user.
  URL: /
  Sign-In URL: /signin
  Project Select URL: /projects
  User Management URL: /users
end note

note right of screen_signin
  Display this screen when user is not signed in.
  Display requested UI after successful sign-in.
end note

note right of panel_task
  No progress monitoring UI.
  Focus on selection under budget.
end note

note bottom of screen_workspace
  URL: /projects/{project_id}/sprints/{sprint_id}/workspace
  Carry-Over Dialog URL:
  /projects/{project_id}/sprints/{sprint_id}/workspace?dialog=carryover
end note

note bottom of screen_project_register
  URL: /projects/new
end note

note bottom of screen_resource
  URL: /projects/{project_id}/resources
end note

note bottom of screen_calendar
  URL: /projects/{project_id}/calendar
end note

@enduml
